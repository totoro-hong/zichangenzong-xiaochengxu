.detail-page {
  min-height: 100vh;
  background: var(--bg);
}

.detail-scroll {
  height: 100vh;
  padding: 24rpx 28rpx 80rpx;
}

/* ── Group hero ── */
.group-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 28rpx;
  margin-bottom: 20rpx;
}

.group-hero-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, var(--primary-light), rgba(212, 168, 84, 0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.group-hero-avatar text {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary);
}

.group-hero-name {
  font-size: 40rpx;
  font-weight: 700;
  font-family: var(--font-heading);
  margin-bottom: 28rpx;
}

.group-hero-stats {
  display: flex;
  gap: 48rpx;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.hero-stat-value {
  font-size: 32rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.hero-stat-label {
  font-size: 22rpx;
  color: var(--muted);
}

/* ── Members ── */
.members-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.members-header {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid var(--sidebar-border);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  font-family: var(--font-heading);
}

.member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.member-row + .member-row {
  border-top: 1px solid var(--sidebar-border);
}

.member-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-avatar text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--primary);
}

.member-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.member-name {
  font-size: 26rpx;
  font-weight: 500;
}

.member-id {
  font-size: 20rpx;
  color: var(--muted);
  opacity: 0.6;
}

/* ── Join card (non-member) ── */
.join-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 28rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, rgba(59, 158, 110, 0.06), rgba(59, 158, 110, 0.02));
  border: 1px solid rgba(59, 158, 110, 0.15);
}

.join-card-title {
  font-size: 32rpx;
  font-weight: 600;
  font-family: var(--font-heading);
  margin-bottom: 12rpx;
}

.join-card-desc {
  font-size: 26rpx;
  color: var(--muted);
  text-align: center;
}

/* ── Invite ── */
.invite-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.invite-desc {
  font-size: 24rpx;
  color: var(--muted);
  margin-top: 12rpx;
  display: block;
}

.invite-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

/* ── Delete (owner only) ── */
.delete-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1px solid rgba(231, 76, 60, 0.2);
  background: rgba(231, 76, 60, 0.04);
}

.btn-danger {
  background: #e74c4c;
  color: #fff;
  border: none;
}

.btn-danger:active {
  background: #c0392b;
}
