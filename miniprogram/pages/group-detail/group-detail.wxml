<wxs src="../../utils/format.wxs" module="fmt" />

<view class="detail-page">
  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
  </view>

  <!-- Join success animation -->
  <view wx:elif="{{joinSuccess}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text style="margin-top: 24rpx; color: var(--muted); font-size: 26rpx;">加载群组数据...</text>
  </view>

  <scroll-view wx:elif="{{group}}" class="detail-scroll" scroll-y>
    <!-- Group hero -->
    <view class="group-hero glass">
      <view class="group-hero-avatar">
        <text>{{fmt.getFirstChar(group.name)}}</text>
      </view>
      <text class="group-hero-name">{{group.name}}</text>
      <view class="group-hero-stats">
        <view class="hero-stat">
          <text class="hero-stat-value">{{assetCount}}</text>
          <text class="hero-stat-label">资产</text>
        </view>
        <view class="hero-stat">
          <text class="hero-stat-value">{{members.length}}</text>
          <text class="hero-stat-label">成员</text>
        </view>
        <view class="hero-stat">
          <text class="hero-stat-value">{{formattedTotal}}</text>
          <text class="hero-stat-label">总资产</text>
        </view>
      </view>
    </view>

    <!-- Join prompt for non-members -->
    <view wx:if="{{!isMember}}" class="join-card glass">
      <text class="join-card-title">你还未加入此群组</text>
      <text class="join-card-desc">加入后可查看和编辑群组内的资产数据</text>
      <button class="btn btn-primary btn-medium" bindtap="handleJoinGroup" disabled="{{joining}}" style="width: 80%; margin-top: 24rpx;">
        {{joining ? '加入中...' : '加入群组'}}
      </button>
    </view>

    <!-- Members card (show for both members and non-members) -->
    <view class="members-card glass">
      <view class="members-header">
        <text class="section-title">群组成员</text>
      </view>
      <view
        wx:for="{{members}}"
        wx:key="_id"
        class="member-row"
      >
        <view class="member-left">
          <view class="member-avatar">
            <text>{{fmt.getFirstChar(item.nickName || '用户')}}</text>
          </view>
          <view class="member-info">
            <text class="member-name">{{item.nickName || '用户'}}</text>
            <text class="member-id">ID: {{item.userId.slice(0, 8)}}...</text>
          </view>
        </view>
        <view class="tag {{item.role === 'owner' ? 'tag-primary' : item.role === 'admin' ? 'tag-gold' : 'tag-muted'}}">
          {{item.role === 'owner' ? '所有者' : item.role === 'admin' ? '管理员' : '成员'}}
        </view>
      </view>
    </view>

    <!-- Invite card (only for members) -->
    <view wx:if="{{isMember}}" class="invite-card glass">
      <text class="section-title">邀请成员</text>
      <text class="invite-desc">分享给好友或复制信息邀请加入</text>
      <view class="invite-actions">
        <button class="btn btn-primary btn-small" open-type="share" style="flex: 1;">
          分享给微信好友
        </button>
        <button class="btn btn-outline btn-small" bindtap="copyInviteInfo" style="flex: 1;">
          复制群组信息
        </button>
      </view>
    </view>

    <!-- Delete group (only for owner) -->
    <view wx:if="{{isOwner}}" class="delete-card glass">
      <text class="section-title" style="color: #e74c4c;">危险操作</text>
      <text class="invite-desc">删除群组将同时清除所有资产数据，不可恢复</text>
      <button class="btn btn-danger btn-small" bindtap="handleDeleteGroup" style="width: 80%; margin-top: 20rpx;">
        删除群组
      </button>
    </view>
  </scroll-view>
</view>
