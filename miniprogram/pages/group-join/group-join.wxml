<view class="join-page">
  <view class="join-header">
    <text class="page-title">加入群组</text>
    <text class="page-desc">输入群组ID来查找并加入</text>
  </view>

  <view class="search-card glass">
    <view class="form-group">
      <text class="form-label">群组ID</text>
      <input
        class="form-input"
        placeholder="粘贴或输入群组ID"
        value="{{groupId}}"
        bindinput="onInput"
      />
    </view>
    <button class="btn btn-primary submit-btn" bindtap="searchGroup" disabled="{{searching}}">
      {{searching ? '查找中...' : '查找群组'}}
    </button>
  </view>

  <view wx:if="{{error}}" class="error-banner">
    <text>{{error}}</text>
  </view>

  <view wx:if="{{group}}" class="result-card glass">
    <view class="result-hero">
      <view class="result-avatar">
        <text>{{group.name}}</text>
      </view>
      <view class="result-info">
        <text class="result-name">{{group.name}}</text>
        <text class="result-id">ID: {{groupId}}</text>
      </view>
    </view>

    <view class="result-divider"></view>

    <view class="result-members">
      <text class="result-members-title">群组成员（{{members.length}}人）</text>
      <view wx:for="{{members}}" wx:for-item="m" wx:key="_id" class="result-member-row">
        <view class="member-left">
          <view class="member-mini-avatar">
            <text>{{m.nickName ? m.nickName[0] : '?'}}</text>
          </view>
          <text class="member-mini-name">{{m.nickName || '用户'}}</text>
        </view>
        <text class="tag tag-primary">{{m.role === 'owner' ? '所有者' : '成员'}}</text>
      </view>
    </view>

    <view class="result-actions">
      <button wx:if="{{joined || alreadyJoined}}" class="btn btn-outline submit-btn" bindtap="goToGroupDetail">
        查看群组
      </button>
      <button wx:else class="btn btn-primary submit-btn" bindtap="handleJoin" disabled="{{joining}}">
        {{joining ? '加入中...' : '加入群组'}}
      </button>
    </view>
  </view>
</view>
