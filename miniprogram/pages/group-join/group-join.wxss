.join-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 24rpx 28rpx 60rpx;
}

.join-header {
  margin-bottom: 28rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  font-family: var(--font-heading);
}

.page-desc {
  font-size: 26rpx;
  color: var(--muted);
  margin-top: 8rpx;
  display: block;
}

/* ── Search card ── */
.search-card {
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.search-row {
  position: relative;
}

.search-input {
  padding-right: 80rpx;
}

.clear-btn {
  position: absolute;
  right: 16rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--muted);
  opacity: 0.5;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 20rpx;
}

/* ── Error banner ── */
.error-banner {
  background: var(--destructive-light);
  border: 1px solid rgba(231, 76, 76, 0.2);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: var(--destructive);
}

/* ── Result card ── */
.result-card {
  padding: 28rpx;
}

.result-hero {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.result-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, var(--primary-light), rgba(212, 168, 84, 0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.result-avatar text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.result-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.result-name {
  font-size: 32rpx;
  font-weight: 600;
  font-family: var(--font-heading);
}

.result-id {
  font-size: 22rpx;
  color: var(--muted);
  opacity: 0.6;
}

.result-divider {
  height: 1px;
  background: var(--sidebar-border);
  margin: 24rpx 0;
}

.result-members-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--muted);
  margin-bottom: 16rpx;
  display: block;
}

.result-member-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.result-member-row + .result-member-row {
  border-top: 1px solid var(--sidebar-border);
}

.member-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-mini-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-mini-avatar text {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--primary);
}

.member-mini-name {
  font-size: 26rpx;
}

.result-actions {
  margin-top: 28rpx;
}
