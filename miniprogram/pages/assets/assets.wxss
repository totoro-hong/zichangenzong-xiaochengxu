.assets-page {
  min-height: 100vh;
  background: var(--bg);
  padding: 20rpx 28rpx 140rpx;
  position: relative;
}

/* ── Search bar ── */
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  height: 56rpx;
  font-size: 26rpx;
  color: var(--foreground);
}

.search-input::placeholder {
  color: var(--muted);
  opacity: 0.5;
}

.search-toggle {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  background: var(--primary-light);
  border-radius: 10rpx;
}

.toggle-text {
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 500;
}

/* ── Category pills ── */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-pills {
  display: flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 28rpx;
  background: rgba(255, 255, 255, 0.55);
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 40rpx;
  font-size: 24rpx;
  color: var(--muted);
  backdrop-filter: blur(8px);
  transition: all 0.2s;
}

.pill-active {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

.pill-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

/* ── Asset cards ── */
.asset-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.asset-card {
  padding: 24rpx;
}

.asset-card:active {
  opacity: 0.85;
}

.asset-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.asset-card-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.asset-card-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--primary);
  flex-shrink: 0;
  line-height: 48rpx;
  text-align: center;
}

.asset-card-name {
  font-size: 28rpx;
  font-weight: 600;
}

.asset-card-mid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.asset-card-date {
  font-size: 22rpx;
  color: var(--muted);
}

.asset-card-bottom {
  display: flex;
  padding-top: 16rpx;
  border-top: 1px solid var(--sidebar-border);
}

.asset-card-field {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.asset-card-label {
  font-size: 20rpx;
  color: var(--muted);
}

.asset-card-amount {
  font-size: 28rpx;
  font-weight: 600;
  font-variant-numeric: tabular-nums;
}

.asset-card-amount-primary {
  color: var(--primary);
}

.asset-card-hidden {
  font-size: 28rpx;
  color: var(--muted);
  opacity: 0.4;
  letter-spacing: 4rpx;
}

.asset-card-divider {
  width: 1px;
  background: var(--sidebar-border);
  margin: 0 24rpx;
}

/* ── FAB ── */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), #2d8a5e);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(59, 158, 110, 0.35);
  z-index: 100;
  transition: transform 0.2s;
}

.fab:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 48rpx;
  font-weight: 300;
  line-height: 1;
}

/* ── Guest state ── */
.guest-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 60rpx 40rpx;
}

.guest-icon-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, rgba(59, 158, 110, 0.1), rgba(212, 168, 84, 0.06));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.guest-state-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--foreground);
  margin-bottom: 12rpx;
}

.guest-state-desc {
  font-size: 26rpx;
  color: var(--muted);
  text-align: center;
}
