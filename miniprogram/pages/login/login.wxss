.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  position: relative;
  overflow: hidden;
  background: #f4f8f6;
}

/* Background orbs */
.bg-orb {
  position: fixed;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.bg-orb-emerald {
  width: 500rpx;
  height: 500rpx;
  background: rgba(59, 158, 110, 0.12);
  top: -200rpx;
  right: -200rpx;
}

.bg-orb-gold {
  width: 400rpx;
  height: 400rpx;
  background: rgba(212, 168, 84, 0.08);
  bottom: -100rpx;
  left: -100rpx;
}

.bg-orb-teal {
  width: 450rpx;
  height: 450rpx;
  background: rgba(91, 127, 255, 0.06);
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.login-content {
  position: relative;
  z-index: 1;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Brand */
.brand-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.logo-container {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, rgba(59, 158, 110, 0.15), rgba(212, 168, 84, 0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.3);
}

.logo-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-img {
  width: 64rpx;
  height: 64rpx;
}

.brand-title {
  font-size: 52rpx;
  font-weight: 700;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  font-size: 28rpx;
  color: var(--muted);
  margin-top: 12rpx;
}

/* Feature list */
.feature-list {
  width: 100%;
  padding: 32rpx 36rpx;
  margin-bottom: 48rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 0;
}

.feature-item + .feature-item {
  border-top: 1px solid var(--sidebar-border);
}

.feature-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.feature-text {
  font-size: 28rpx;
  color: var(--foreground);
}

/* Login actions */
.login-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  font-size: 32rpx;
  border-radius: 20rpx;
}

.quick-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 20rpx;
}

.login-footer {
  font-size: 22rpx;
  color: var(--muted);
  opacity: 0.6;
}

/* ── Privacy section ── */
.privacy-section {
  width: 100%;
  padding: 24rpx 28rpx;
  margin-bottom: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.privacy-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.privacy-checkbox {
  width: 36rpx;
  height: 36rpx;
  border-radius: 6rpx;
  border: 2px solid var(--muted);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.privacy-checkbox.checked {
  background: var(--primary);
  border-color: var(--primary);
}

.checkmark {
  width: 12rpx;
  height: 20rpx;
  border: 2px solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg);
  margin-top: -2rpx;
}

.privacy-label {
  font-size: 24rpx;
  color: var(--muted);
}

.privacy-links {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
}

.privacy-link {
  color: var(--primary);
  text-decoration: underline;
}

.privacy-link:active {
  opacity: 0.7;
}

.privacy-sep {
  color: var(--muted);
}

.quick-btn {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 20rpx;
}

.loading-spinner-small {
  width: 32rpx;
  height: 32rpx;
  border: 3px solid rgba(255,255,255,0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}
